# Manifest: prefer GCS (same bucket as images). Object key or gs://cv-urban-accessibility-bucket/...
POINTS_MANIFEST_BLOB=streetview/polygon_4v/20260329T023321Z-BAGDAT-30m/manifest.csv

# Fallback when POINTS_MANIFEST_BLOB is unset (local dev / offline).
# POINTS_MANIFEST_CSV=resources/streetview_polygon_4v_20260329T023321Z-BAGDAT-30m_manifest.csv

GCS_BUCKET_NAME=cv-urban-accessibility-bucket
GCP_PROJECT_ID=cv-urban-accessibility
GCS_PREFIX_REPORTS=reports

# Originals: default streetview/ covers streetview/polygon_4v/<run>/… in the manifest.
# Use a full run prefix only if you want to restrict /api/image to one folder:
# GCS_PREFIX_ORIGINAL=streetview/polygon_4v/20260329T023321Z-BAGDAT-30m
GCS_PREFIX_ORIGINAL=streetview

GCS_PREFIX_SEGMENTATION=v3/segmentation-results
GCS_PREFIX_VISUALIZATION=v3/visualization-results

# Optional: comma-separated extra roots allowed by /api/image (beyond the four prefixes above).
# GCS_EXTRA_ALLOWED_PREFIXES=v2/legacy-visualization

